# ==============================================================================
# 🚀 Backend Dockerfile - Fastion E-Commerce
# Base: Node.js 21 Alpine (Lightweight & Secure)
# ==============================================================================

# ------------------------------------------------------------------------------
# 📦 Base Image
# ------------------------------------------------------------------------------
FROM node:21-alpine

# ------------------------------------------------------------------------------
# 📁 Working Directory
# ------------------------------------------------------------------------------
WORKDIR /app

# ------------------------------------------------------------------------------
# 🔧 System Dependencies
# Required for bcrypt and other native modules to compile on Alpine Linux
# ------------------------------------------------------------------------------
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    wget

# ------------------------------------------------------------------------------
# 🌍 Environment
# ------------------------------------------------------------------------------
ENV NODE_ENV=production

# ------------------------------------------------------------------------------
# 📥 Install Dependencies
# Copy package files first for better Docker layer caching
# ------------------------------------------------------------------------------
COPY package*.json ./
RUN npm install --omit=dev

# ------------------------------------------------------------------------------
# 📂 Copy Source Code
# ------------------------------------------------------------------------------
COPY . .

# ------------------------------------------------------------------------------
# 🔒 Security - Non-Root User
# Running as non-root user to minimize security risks
# ------------------------------------------------------------------------------
RUN addgroup --system appgroup \
    && adduser -S appuser -G appgroup \
    && chown -R appuser:appgroup /app

USER appuser

# ------------------------------------------------------------------------------
# 🌐 Expose Port
# ------------------------------------------------------------------------------
EXPOSE 8000

# ------------------------------------------------------------------------------
# ❤️ Health Check
# Verifies server is running and responsive
# ------------------------------------------------------------------------------
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD wget -q --spider http://localhost:8000/ || exit 1

# ------------------------------------------------------------------------------
# ▶️ Start Application
# ------------------------------------------------------------------------------
CMD ["node", "src/app.js"]
